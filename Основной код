@st.cache_data
def load_data():
    data_path = Path(__file__).parent / "data" / "benefits.json"
    with open(data_path, "r", encoding="utf-8") as f:
        return json.load(f)


def get_all_benefits(data):
    """Получить все льготы единым списком"""
    all_benefits = []
    for category in data["categories"]:
        for benefit in category["benefits"]:
            benefit_copy = benefit.copy()
            benefit_copy["category_name"] = category["name"]
            benefit_copy["category_icon"] = category["icon"]
            benefit_copy["category_id"] = category["id"]
            all_benefits.append(benefit_copy)
    return all_benefits


def search_benefits(all_benefits, query):
    """Поиск по льготам"""
    query = query.lower().strip()
    results = []
    for b in all_benefits:
        searchable = f"{b['title']} {b['description']} {' '.join(b['who'])} {b['category_name']}".lower()
        if query in searchable:
            results.append(b)
    return results


def render_benefit_card(benefit):
    """Отрисовка карточки льготы"""
    who_list = "".join([f"<li>{w}</li>" for w in benefit["who"]])
    docs_list = "".join([f"<li>{d}</li>" for d in benefit["documents"]])

    st.markdown(f"""
    <div class="benefit-card">
        <div class="benefit-title">{benefit['category_icon']} {benefit['title']}</div>
        <div class="benefit-amount">💵 {benefit['amount']}</div>
        <div class="benefit-description">{benefit['description']}</div>

        <div class="info-block">
            <div class="info-block-title">👤 Кому положено:</div>
            <div class="info-block-content">
                <ul style="margin: 0; padding-left: 1.2rem;">{who_list}</ul>
            </div>
        </div>

        <div class="info-block">
            <div class="info-block-title">📄 Документы:</div>
            <div class="info-block-content">
                <ul style="margin: 0; padding-left: 1.2rem;">{docs_list}</ul>
            </div>
        </div>

        <div class="info-block">
            <div class="info-block-title">🏢 Куда обращаться:</div>
            <div class="info-block-content">{benefit['where']}</div>
        </div>

        <a href="{benefit['link']}" target="_blank" class="apply-button">
            Перейти к оформлению →
        </a>
    </div>
    """, unsafe_allow_html=True)


