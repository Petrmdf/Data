# ============================================
def render_search(all_benefits):
    st.markdown("## 🔍 Поиск по всем льготам и выплатам")
    st.markdown("Введите ключевое слово: название выплаты, категорию людей или жизненную ситуацию.")

    query = st.text_input(
        "Поиск",
        placeholder="Например: ребёнок, ипотека, пенсия, инвалидность, студент, безработный...",
        label_visibility="collapsed"
    )

    if query:
        results = search_benefits(all_benefits, query)
        st.markdown(f"""
        <div class="search-result-count">
            Найдено результатов: <strong>{len(results)}</strong>
        </div>
        """, unsafe_allow_html=True)

        if results:
            for b in results:
                render_benefit_card(b)
        else:
            st.info("😕 Ничего не найдено. Попробуйте другие ключевые слова.")
            st.markdown("**Подсказки для поиска:**")
            st.markdown("- материнский капитал")
            st.markdown("- налоговый вычет")
            st.markdown("- пособие по безработице")
            st.markdown("- субсидия ЖКХ")
    else:
        st.info("👆 Начните вводить запрос, чтобы найти нужные льготы и выплаты.")


