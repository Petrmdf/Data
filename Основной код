def render_home(data, all_benefits):
    total = len(all_benefits)
    categories_count = len(data["categories"])

    st.markdown(f"""
    <div class="hero-section">
        <div class="hero-title">Узнай, какие льготы и выплаты<br>тебе положены</div>
        <div class="hero-subtitle">
            Пособия, вычеты, компенсации, субсидии — всё в одном месте.<br>
            Простым языком, с суммами и инструкциями.
        </div>
        <div class="hero-stats">
            <div class="hero-stat">
                <div class="hero-stat-number">{total}+</div>
                <div class="hero-stat-label">льгот и выплат</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-number">{categories_count}</div>
                <div class="hero-stat-label">категорий</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-number">2025</div>
                <div class="hero-stat-label">актуальные данные</div>
            </div>
        </div>
    </div>
    """, unsafe_allow_html=True)

    # Быстрый поиск
    st.markdown("### 🔍 Быстрый поиск")
    quick_search = st.text_input(
        "Введите ключевое слово",
        placeholder="Например: материнский капитал, вычет, ипотека, пенсия...",
        label_visibility="collapsed"
    )

    if quick_search:
        results = search_benefits(all_benefits, quick_search)
        if results:
            st.success(f"Найдено: {len(results)} результатов")
            for b in results:
                render_benefit_card(b)
        else:
            st.warning("Ничего не найдено. Попробуйте другой запрос.")
        return

    # Категории
    st.markdown("### 📂 Выберите категорию")

    cols = st.columns(4)
    for i, category in enumerate(data["categories"]):
        col = cols[i % 4]
        with col:
            count = len(category["benefits"])
            st.markdown(f"""
            <div class="category-card">
                <div class="category-icon">{category['icon']}</div>
                <div class="category-name">{category['name']}</div>
                <div class="category-count">{count} выплат</div>
            </div>
            """, unsafe_allow_html=True)
            if st.button(f"Открыть", key=f"cat_{category['id']}", use_container_width=True):
                st.session_state["selected_category"] = category["id"]

    # Показ выбранной категории
    if "selected_category" in st.session_state:
        cat_id = st.session_state["selected_category"]
        for category in data["categories"]:
            if category["id"] == cat_id:
                st.markdown(f"---")
                st.markdown(f"## {category['icon']} {category['name']}")
                for benefit in category["benefits"]:
                    benefit_copy = benefit.copy()
                    benefit_copy["category_icon"] = category["icon"]
                    render_benefit_card(benefit_copy)
                break


