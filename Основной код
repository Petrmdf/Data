# ============================================
def render_quiz(all_benefits):
    st.markdown("## 📋 Подберём льготы под вашу ситуацию")
    st.markdown("Ответьте на несколько вопросов — мы покажем, что вам положено.")

    st.markdown("---")

    # Вопрос 1
    age_group = st.selectbox(
        "👤 Ваш возраст:",
        ["Выберите...", "14–22 года", "23–35 лет", "36–54 года", "55–69 лет", "70+ лет"]
    )

    # Вопрос 2
    has_children = st.selectbox(
        "👶 Есть ли у вас дети?",
        ["Выберите...", "Нет", "Да, один ребёнок", "Да, двое детей", "Да, трое и более детей", "Ожидаю ребёнка"]
    )

    # Вопрос 3
    employment = st.selectbox(
        "💼 Ваш статус занятости:",
        ["Выберите...", "Работаю официально", "Работаю неофициально", "Безработный", "Студент", "Пенсионер", "В декрете", "ИП/Самозанятый"]
    )

    # Вопрос 4
    has_disability = st.selectbox(
        "♿ Есть ли инвалидность?",
        ["Выберите...", "Нет", "I группа", "II группа", "III группа", "Ребёнок-инвалид"]
    )

    # Вопрос 5
    housing = st.selectbox(
        "🏠 Жилищная ситуация:",
        ["Выберите...", "Собственное жильё", "Ипотека", "Аренда", "Планирую покупку", "Нет жилья"]
    )

    st.markdown("---")

    if st.button("🔍 Подобрать льготы", type="primary", use_container_width=True):
        if "Выберите..." in [age_group, has_children, employment, has_disability, housing]:
            st.warning("⚠️ Пожалуйста, ответьте на все вопросы.")
            return

        matched = []

        for b in all_benefits:
            score = 0

            # Логика подбора
            title_lower = b["title"].lower()
            desc_lower = b["description"].lower()
            who_lower = " ".join(b["who"]).lower()
            combined = f"{title_lower} {desc_lower} {who_lower}"

            # Дети
            if has_children != "Нет":
                if any(w in combined for w in ["дет", "ребён", "семь", "мат", "рожден", "школ", "декрет"]):
                    score += 3
                if "трое" in has_children.lower() or "более" in has_children.lower():
                    if any(w in combined for w in ["многодет", "школьн"]):
                        score += 2

            if has_children == "Ожидаю ребёнка":
                if any(w in combined for w in ["беременн", "родам", "рожден"]):
                    score += 3

            # Работа
            if employment == "Работаю официально":
                if any(w in combined for w in ["вычет", "ндфл", "налог", "работающ"]):
                    score += 2

            if employment == "Безработный":
                if any(w in combined for w in ["безработ", "занятост", "переобуч", "пособие по безработице"]):
                    score += 3

            if employment == "Студент":
                if any(w in combined for w in ["студент", "стипенди", "обучен", "пушкин", "молод"]):
                    score += 3

            if employment == "Пенсионер":
                if any(w in combined for w in ["пенсион", "пожил", "проезд", "капремонт", "лекарств"]):
                    score += 3

            if employment == "В декрете":
                if any(w in combined for w in ["декрет", "беременн", "родам", "мам", "переобуч"]):
                    score += 3

            # Инвалидность
            if has_disability != "Нет":
                if any(w in combined for w in ["инвалид", "едв", "реабилит", "парков", "мсэ"]):
                    score += 3

            # Жильё
            if housing in ["Ипотека", "Планирую покупку"]:
                if any(w in combined for w in ["ипотек", "жиль", "покупк", "вычет за покупку"]):
                    score += 3

            if housing in ["Собственное жильё", "Аренда"]:
                if any(w in combined for w in ["жкх", "субсид", "капремонт", "коммунал"]):
                    score += 2

            # Возраст
            if "70+" in age_group:
                if any(w in combined for w in ["капремонт", "пенсион", "пожил"]):
                    score += 2

            if "14–22" in age_group:
                if any(w in combined for w in ["пушкин", "студент", "молод"]):
                    score += 2

            if score > 0:
                b_copy = b.copy()
                b_copy["_score"] = score
                matched.append(b_copy)

        # Сортировка по релевантности
        matched.sort(key=lambda x: x["_score"], reverse=True)

        # Убираем дубли
        seen = set()
        unique_matched = []
        for m in matched:
            if m["title"] not in seen:
                seen.add(m["title"])
                unique_matched.append(m)

        if unique_matched:
            st.success(f"🎯 Найдено {len(unique_matched)} льгот и выплат, которые могут быть вам положены!")
            st.markdown("---")
            for b in unique_matched:
                render_benefit_card(b)
        else:
            st.info("К сожалению, по вашим параметрам не найдено подходящих льгот. Попробуйте изменить ответы или воспользуйтесь поиском.")


# ============================================
# СТРАНИЦА: ВСЕ КАТЕГОРИИ
# ============================================
def render_all_categories(data):
    st.markdown("## 📚 Все льготы и выплаты по категориям")
    st.markdown("Полный каталог всех доступных льгот, пособий и выплат.")

    for category in data["categories"]:
        with st.expander(f"{category['icon']} {category['name']} ({len(category['benefits'])} выплат)", expanded=False):
            for benefit in category["benefits"]:
                benefit_copy = benefit.copy()
                benefit_copy["category_icon"] = category["icon"]
                render_benefit_card(benefit_copy)


