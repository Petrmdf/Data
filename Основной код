        render_home(data, all_benefits)

    # === СТРАНИЦА: ПОИСК ===
    elif page == "🔍 Поиск льгот":
        render_search(all_benefits)

    # === СТРАНИЦА: КВИЗ ===
    elif page == "📋 Подобрать льготы":
        render_quiz(all_benefits)

    # === СТРАНИЦА: ВСЕ КАТЕГОРИИ ===
    elif page == "📚 Все категории":
